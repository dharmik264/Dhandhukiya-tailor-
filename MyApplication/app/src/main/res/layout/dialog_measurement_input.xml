<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="8dp" android:background="@drawable/bg_white_rounded_top">

    <View android:layout_width="40dp" android:layout_height="4dp" android:layout_gravity="center_horizontal" android:layout_marginBottom="8dp" android:background="#DDDDDD" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">

        <TextView android:id="@+id/tvSheetTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Shirt Size" android:textSize="18sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Inches" android:textColor="@color/red_dark" android:textSize="11sp" android:textStyle="bold" />
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:scrollbars="none">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

            <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:columnCount="2" android:useDefaultMargins="false">

                <!-- Row 1 -->
                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilSheet1" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="2dp" app:boxStrokeColor="@color/red_dark" app:hintTextColor="@color/red_dark">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSheet1" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textSize="13sp" android:padding="10dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilSheet2" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="2dp" app:boxStrokeColor="@color/red_dark" app:hintTextColor="@color/red_dark">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSheet2" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textSize="13sp" android:padding="10dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Row 2 -->
                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilSheet3" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="2dp" app:boxStrokeColor="@color/red_dark" app:hintTextColor="@color/red_dark">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSheet3" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textSize="13sp" android:padding="10dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilSheet4" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="2dp" app:boxStrokeColor="@color/red_dark" app:hintTextColor="@color/red_dark">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSheet4" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textSize="13sp" android:padding="10dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Row 3 -->
                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilSheet5" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="2dp" app:boxStrokeColor="@color/red_dark" app:hintTextColor="@color/red_dark">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSheet5" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textSize="13sp" android:padding="10dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilSheet6" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="2dp" app:boxStrokeColor="@color/red_dark" app:hintTextColor="@color/red_dark">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSheet6" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textSize="13sp" android:padding="10dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Row 4 -->
                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilSheet7" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="2dp" app:boxStrokeColor="@color/red_dark" app:hintTextColor="@color/red_dark">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSheet7" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textSize="13sp" android:padding="10dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilSheet8" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="2dp" app:boxStrokeColor="@color/red_dark" app:hintTextColor="@color/red_dark">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSheet8" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textSize="13sp" android:padding="10dp"/>
                </com.google.android.material.textfield.TextInputLayout>

            </GridLayout>

            <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:hint="Notes" app:boxStrokeColor="@color/red" app:hintTextColor="@color/red">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSheetNotes" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="top" android:inputType="textMultiLine" android:lines="2" android:textSize="13sp" android:padding="10dp"/>
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton android:id="@+id/btnSheetSave" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="8dp" android:text="Save Measurement" android:backgroundTint="@color/red_dark" android:textColor="@android:color/white" android:textStyle="bold" app:cornerRadius="12dp" />

</LinearLayout>
