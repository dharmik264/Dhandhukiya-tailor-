<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/background">

    <!-- Responsive Content Wrapper -->
    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="0dp" android:layout_height="match_parent" app:layout_constraintWidth_max="@dimen/max_content_width" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">

        <!-- Top Bar -->
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/topBar" android:layout_width="match_parent" android:layout_height="80dp" android:background="@color/red_dark" app:layout_constraintTop_toTopOf="parent">
            <com.google.android.material.card.MaterialCardView android:id="@+id/btnBackCard" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginStart="16dp" app:cardCornerRadius="10dp" app:cardElevation="0dp" app:cardBackgroundColor="@color/card_background" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent">
                <ImageView android:id="@+id/btnBack" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@drawable/ic_back_arrow" app:tint="@color/on_surface" />
            </com.google.android.material.card.MaterialCardView>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Customer Details" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:fillViewport="true" app:layout_constraintBottom_toTopOf="@id/btnNewOrder" app:layout_constraintTop_toBottomOf="@id/topBar">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <!-- Profile Info Card -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardGarmentMain" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" app:cardCornerRadius="16dp" app:cardElevation="2dp" app:strokeColor="@color/divider" app:cardBackgroundColor="@color/card_background">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                        <FrameLayout android:layout_width="72dp" android:layout_height="72dp">
                            <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_circle_black" android:backgroundTint="@color/error_bg" />
                            <TextView android:id="@+id/tvInitials" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="JD" android:textColor="@color/red_dark" android:textSize="22sp" android:textStyle="bold" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:id="@+id/tvName" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="James Dalton" android:textColor="@color/on_surface" android:textSize="20sp" android:textStyle="bold" />
                            <TextView android:id="@+id/tvMobile" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="+1 (555) 123-4567" android:textColor="@color/on_surface_variant" android:textSize="14sp" android:layout_marginTop="2dp" />
                            <TextView android:id="@+id/tvAddress" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="123 Street Name, City" android:textColor="@color/on_surface_variant" android:textSize="12sp" android:layout_marginTop="2dp" />
                            <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Status: Pending" android:textColor="@color/error_text" android:textSize="11sp" android:textStyle="bold" android:paddingHorizontal="10dp" android:paddingVertical="4dp" android:layout_marginTop="8dp" android:background="@drawable/bg_badge_rounded" android:backgroundTint="@color/error_bg"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Garment Type Section -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Garment Type" android:layout_marginTop="24dp" android:textColor="@color/on_surface" android:textStyle="bold" android:textSize="17sp" />

                <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:scrollbars="none">
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnShirtProfile" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shirt" android:textAllCaps="false" android:textSize="13sp" app:cornerRadius="10dp" android:layout_marginEnd="10dp" android:backgroundTint="@color/divider" android:textColor="@color/on_surface_variant"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnPantProfile" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pant" android:textAllCaps="false" android:textSize="13sp" app:cornerRadius="10dp" android:layout_marginEnd="10dp" android:backgroundTint="@color/red_dark" android:textColor="#FFFFFF"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnKotiProfile" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Koti" android:textAllCaps="false" android:textSize="13sp" app:cornerRadius="10dp" android:layout_marginEnd="10dp" android:backgroundTint="@color/divider" android:textColor="@color/on_surface_variant"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnSuitProfile" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Suit" android:textAllCaps="false" android:textSize="13sp" app:cornerRadius="10dp" android:layout_marginEnd="10dp" android:backgroundTint="@color/divider" android:textColor="@color/on_surface_variant"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnJabbhoProfile" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jabbho" android:textAllCaps="false" android:textSize="13sp" app:cornerRadius="10dp" android:layout_marginEnd="10dp" android:backgroundTint="@color/divider" android:textColor="@color/on_surface_variant"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnLehnghoProfile" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lehngho" android:textAllCaps="false" android:textSize="13sp" app:cornerRadius="10dp" android:layout_marginEnd="10dp" android:backgroundTint="@color/divider" android:textColor="@color/on_surface_variant"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnSafariProfile" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Safari" android:textAllCaps="false" android:textSize="13sp" app:cornerRadius="10dp" android:layout_marginEnd="10dp" android:backgroundTint="@color/divider" android:textColor="@color/on_surface_variant"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnJodhpuriProfile" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jodhpuri" android:textAllCaps="false" android:textSize="13sp" app:cornerRadius="10dp" android:backgroundTint="@color/divider" android:textColor="@color/on_surface_variant"/>
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Measurements Section -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardMeasurementDisplay" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" app:cardCornerRadius="16dp" app:cardElevation="2dp" app:strokeColor="@color/divider" app:cardBackgroundColor="@color/card_background">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:id="@+id/tvUnifiedGarmentTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Measurements" android:textStyle="bold" android:textColor="@color/on_surface" android:textSize="17sp" />
                            <com.google.android.material.button.MaterialButton android:id="@+id/btnEditUnified" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Edit" android:textColor="@color/red_dark" app:icon="@drawable/ic_pencil_edit" app:iconTint="@color/red_dark" android:textSize="12sp"/>
                        </LinearLayout>

                        <FrameLayout android:id="@+id/layoutMeasurementsCollapse" android:layout_width="match_parent" android:layout_height="wrap_content">
                            <GridLayout android:id="@+id/displayGrid" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:columnCount="2">
                                <!-- Container 1 -->
                                <LinearLayout android:id="@+id/container1" style="@style/MeasurementFieldStyle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1">
                                    <TextView android:id="@+id/tvLabel1" style="@style/MeasurementLabelStyle" android:text="Label" />
                                    <TextView android:id="@+id/tvValue1" style="@style/MeasurementValueStyle" android:text="Value" />
                                </LinearLayout>
                                <!-- Container 2 -->
                                <LinearLayout android:id="@+id/container2" style="@style/MeasurementFieldStyle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1">
                                    <TextView android:id="@+id/tvLabel2" style="@style/MeasurementLabelStyle" android:text="Label" />
                                    <TextView android:id="@+id/tvValue2" style="@style/MeasurementValueStyle" android:text="Value" />
                                </LinearLayout>
                                <!-- Container 3 -->
                                <LinearLayout android:id="@+id/container3" style="@style/MeasurementFieldStyle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1">
                                    <TextView android:id="@+id/tvLabel3" style="@style/MeasurementLabelStyle" android:text="Label" />
                                    <TextView android:id="@+id/tvValue3" style="@style/MeasurementValueStyle" android:text="Value" />
                                </LinearLayout>
                                <!-- Container 4 -->
                                <LinearLayout android:id="@+id/container4" style="@style/MeasurementFieldStyle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1">
                                    <TextView android:id="@+id/tvLabel4" style="@style/MeasurementLabelStyle" android:text="Label" />
                                    <TextView android:id="@+id/tvValue4" style="@style/MeasurementValueStyle" android:text="Value" />
                                </LinearLayout>
                                <!-- Container 5 -->
                                <LinearLayout android:id="@+id/container5" style="@style/MeasurementFieldStyle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1">
                                    <TextView android:id="@+id/tvLabel5" style="@style/MeasurementLabelStyle" android:text="Label" />
                                    <TextView android:id="@+id/tvValue5" style="@style/MeasurementValueStyle" android:text="Value" />
                                </LinearLayout>
                                <!-- Container 6 -->
                                <LinearLayout android:id="@+id/container6" style="@style/MeasurementFieldStyle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1">
                                    <TextView android:id="@+id/tvLabel6" style="@style/MeasurementLabelStyle" android:text="Label" />
                                    <TextView android:id="@+id/tvValue6" style="@style/MeasurementValueStyle" android:text="Value" />
                                </LinearLayout>
                                <!-- Container 7 -->
                                <LinearLayout android:id="@+id/container7" style="@style/MeasurementFieldStyle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1">
                                    <TextView android:id="@+id/tvLabel7" style="@style/MeasurementLabelStyle" android:text="Label" />
                                    <TextView android:id="@+id/tvValue7" style="@style/MeasurementValueStyle" android:text="Value" />
                                </LinearLayout>
                                <!-- Container 8 -->
                                <LinearLayout android:id="@+id/container8" style="@style/MeasurementFieldStyle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1">
                                    <TextView android:id="@+id/tvLabel8" style="@style/MeasurementLabelStyle" android:text="Label" />
                                    <TextView android:id="@+id/tvValue8" style="@style/MeasurementValueStyle" android:text="Value" />
                                </LinearLayout>
                            </GridLayout>
                        </FrameLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Notes" android:textColor="@color/on_surface_variant" android:textSize="12sp" android:textStyle="bold" android:layout_marginTop="16dp" />
                        <TextView android:id="@+id/tvNotesValue" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="No notes available" android:textColor="@color/on_surface" android:textSize="14sp" />

                        <LinearLayout android:id="@+id/layoutOrderActions" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:orientation="horizontal">
                            <com.google.android.material.button.MaterialButton android:id="@+id/btnInProgress" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="8dp" android:text="In Progress" android:textAllCaps="false" android:textColor="@color/on_surface" app:strokeColor="@color/divider" app:cornerRadius="10dp" />
                            <com.google.android.material.button.MaterialButton android:id="@+id/btnCompleted" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Completed" android:textAllCaps="false" android:backgroundTint="#4CAF50" android:textColor="@color/white" app:cornerRadius="10dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>

        <com.google.android.material.button.MaterialButton android:id="@+id/btnNewOrder" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginHorizontal="16dp" android:layout_marginBottom="8dp" android:text="+ NEW ORDER" android:backgroundTint="@color/red_dark" app:cornerRadius="12dp" android:textStyle="bold" app:layout_constraintBottom_toTopOf="@id/mainBottomNavigation" />
        <include layout="@layout/reusable_bottom_navigation" android:id="@+id/mainBottomNavigation" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
