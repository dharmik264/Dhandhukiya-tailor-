<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/card_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Left Status Strip -->
        <View
            android:id="@+id/statusStrip"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@color/red_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Initials Circle -->
        <FrameLayout
            android:id="@+id/initialsContainer"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/statusStrip"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_circle_light_gray" />

            <TextView
                android:id="@+id/tvCheckInitials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="JS"
                android:textColor="@color/red_dark"
                android:textSize="18sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Order Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/initialsContainer"
            app:layout_constraintEnd_toStartOf="@id/badgeContainer"
            app:layout_constraintStart_toEndOf="@id/initialsContainer"
            app:layout_constraintTop_toTopOf="@id/initialsContainer">

            <TextView
                android:id="@+id/tvCheckCustomerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="James Smith"
                android:textColor="@color/on_surface"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCheckMobile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="+1 234 567 890"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvCheckDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="OCT 24, 2023"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:textAllCaps="true" />
        </LinearLayout>

        <!-- Right Side Badges -->
        <LinearLayout
            android:id="@+id/badgeContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:gravity="end"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Garment Type Badge -->
            <TextView
                android:id="@+id/tvCheckGarmentType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_rounded"
                android:backgroundTint="@color/info_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:text="SUIT"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Status Badge -->
            <TextView
                android:id="@+id/tvCheckStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_badge_rounded"
                android:backgroundTint="@color/error_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="2dp"
                android:text="PENDING"
                android:textColor="@color/error_text"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
