<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/background">

    <!-- Content Wrapper for Responsiveness -->
    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="0dp" android:layout_height="match_parent" app:layout_constraintWidth_max="@dimen/max_content_width" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent">

        <!-- Header Background -->
        <View android:id="@+id/headerBackground" android:layout_width="match_parent" android:layout_height="@dimen/header_height" android:background="@drawable/bg_header_rounded" app:layout_constraintTop_toTopOf="parent" />

        <ImageView android:id="@+id/ivShopLogo" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginStart="16dp" android:layout_marginTop="16dp" android:src="@drawable/dt" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:tint="@android:color/white" />

        <TextView android:id="@+id/tvShopName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Dhandhukiya Tailor Shop" android:textColor="@android:color/white" android:textSize="@dimen/text_size_header" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="@id/ivShopLogo" app:layout_constraintEnd_toStartOf="@id/ivNotification" app:layout_constraintStart_toEndOf="@id/ivShopLogo" app:layout_constraintTop_toTopOf="@id/ivShopLogo" />

        <ImageView android:id="@+id/ivNotification" android:layout_width="36dp" android:layout_height="36dp" android:layout_marginEnd="16dp" android:background="@drawable/bg_circle_black" android:backgroundTint="#E57373" android:padding="8dp" android:src="@android:drawable/ic_popup_reminder" app:layout_constraintBottom_toBottomOf="@id/ivShopLogo" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/ivShopLogo" app:tint="@android:color/white" />

        <!-- Search Bar -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/searchCard" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginHorizontal="16dp" app:cardCornerRadius="16dp" app:cardElevation="4dp" app:strokeWidth="0dp" app:layout_constraintBottom_toBottomOf="@id/headerBackground" app:layout_constraintTop_toBottomOf="@id/headerBackground">
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="12dp">
                <ImageView android:id="@+id/ivSearch" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_search" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:tint="@color/on_surface_variant" />
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSearch" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="12dp" android:background="@android:color/transparent" android:hint="Search customers" android:inputType="text" android:textSize="14sp" app:layout_constraintEnd_toStartOf="@id/ivFilter" app:layout_constraintStart_toEndOf="@id/ivSearch" />
                <ImageView android:id="@+id/ivFilter" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_sort_by_size" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:tint="@color/red_dark" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Alphabet Bar -->
        <HorizontalScrollView android:id="@+id/svAlphabet" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:paddingHorizontal="16dp" android:scrollbars="none" app:layout_constraintTop_toBottomOf="@id/searchCard">
            <LinearLayout android:id="@+id/layoutAlphabetBar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/btnAll" android:layout_width="48dp" android:layout_height="32dp" android:text="ALL" android:textSize="12sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_circle_red" android:textColor="@android:color/white" android:layout_marginEnd="8dp"/>
            </LinearLayout>
        </HorizontalScrollView>

        <TextView android:id="@+id/tvCustomerListTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="20dp" android:text="Recent Customers" android:textColor="@color/on_surface" android:textSize="@dimen/text_size_subheader" android:textStyle="bold" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/svAlphabet" />

        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvCustomers" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="12dp" android:paddingBottom="8dp" android:clipToPadding="false" app:layout_constraintBottom_toTopOf="@id/mainBottomNavigation" app:layout_constraintTop_toBottomOf="@id/tvCustomerListTitle" tools:listitem="@layout/item_customer" />

        <include layout="@layout/reusable_bottom_navigation" android:id="@+id/mainBottomNavigation" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
